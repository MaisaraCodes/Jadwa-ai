# ==============================================================================
# Jadwa.ai — Backend Environment (.env.example)   →  /backend/.env.example
# ==============================================================================
# --- Server ---
ENV=development
HOST=127.0.0.1
PORT=8000
# Comma-separated origins allowed to call the API (your Vercel URL + local dev).
# Without this, the browser blocks the SME/bank portals.
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# --- OpenAI ---
# Used by ALL model nodes: Document Intelligence (vision), Forensic & Oracle (mini),
# Devil's Advocate (full), and embeddings for the Oracle RAG corpus.
OPENAI_API_KEY=your_openai_api_key_here
# Pin snapshots, not aliases (see CONVENTIONS.md). Confirm exact strings in the dashboard.
OPENAI_MODEL_VISION=gpt-5.4
OPENAI_MODEL_MINI=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# --- Supabase (Auth + Storage + Postgres/pgvector) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Backend-only. Bypasses RLS. NEVER commit or expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Needed to validate the Supabase JWT and derive user_id + role in FastAPI.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
# Direct Postgres connection (synthetic-data script, forensic SQL, pgvector queries).
DATABASE_URL=postgresql://postgres:[password]@db.your-project-id.supabase.co:5432/postgres
# Storage bucket for uploaded documents.
SUPABASE_STORAGE_BUCKET=application-documents

# --- LangSmith tracing (recommended for the demo) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=jadwa-ai-agents
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- App settings ---
ENABLE_MOCK_OPEN_BANKING=true
