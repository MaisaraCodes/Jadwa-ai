# ==============================================================================
# Jadwa.ai - Backend Environment Variables Configuration (.env.example)
# ==============================================================================

# --- Server Configuration ---
ENV=development
HOST=127.0.0.1
PORT=8000

# --- OpenAI API Credentials ---
# Used by Worker Agents (Forensic Accountant) and Reasoning Agents (Devil's Advocate)
OPENAI_API_KEY=your_openai_api_key_here

# --- Supabase & Database Configuration (with pgvector support) ---
# URL of your Supabase project instance
SUPABASE_URL=https://your-project-id.supabase.co
# Anon key for basic client interactions
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key: CRITICAL for backend agents to bypass RLS policies when reading/writing records
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- LangGraph / LangChain Tracing (Highly Recommended for Hackathons) ---
# Setting this to true enables complete visualization of your agent states in LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=jadwa-ai-agents
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Application Specific Settings ---
# Mocking Open Banking Ledger Data for the demo
ENABLE_MOCK_OPEN_BANKING=true
