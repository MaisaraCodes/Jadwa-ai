# ==============================================================================
# Jadwa.ai - Frontend Environment Variables Configuration (.env.example)
# ==============================================================================

# --- API Connection ---
# Points to your local FastAPI backend server during development
VITE_API_URL=http://localhost:8000

# --- Supabase Client Credentials ---
# Publicly accessible keys used by the frontend client to initialize the Supabase SDK
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# NOTE: NEVER expose your SUPABASE_SERVICE_ROLE_KEY or OPENAI_API_KEY in this frontend file.
# Doing so will leak your project credentials to the browser console.
